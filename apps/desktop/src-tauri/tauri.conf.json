{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IRIS Desktop",
  "version": "0.1.0",
  "identifier": "org.drufiy.iris.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "IRIS Desktop",
        "width": 1460,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity"
  }
}
